# ── DocGuard — Server Environment ─────────────────────────
# Copy this file to .env on each server and fill in the values.
# Never commit .env to git.

# Docker Hub username (where your images are stored)
DOCKERHUB_USERNAME=your_dockerhub_username

# Database password — choose something strong
DB_PASSWORD=change_this_strong_password

# Default admin account password for DocGuard login
ADMIN_PASSWORD=change_this_admin_password

# Frontend URL (used for CORS) — set to your server's domain or IP
# Multiple origins: comma-separated
ALLOWED_ORIGINS=http://your-server-ip

# API docs (Swagger UI) — keep false in production
DOCS_ENABLED=false
DOCS_USERNAME=admin
DOCS_PASSWORD=
